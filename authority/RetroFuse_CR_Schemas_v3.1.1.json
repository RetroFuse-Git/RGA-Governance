{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://porttoretro.local/schemas/RetroFuse_CR_Schemas_v3.1.1.json",
  "title": "RetroFuse CR Schemas v3.1.1 — CR_SafePoint.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "identity",
    "authority",
    "determiners",
    "assets_sealed",
    "run_start",
    "known_issues",
    "resume_plan"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v3.1.1"
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "lane",
        "version",
        "safepoint",
        "timestamp"
      ],
      "properties": {
        "project": {
          "type": "string",
          "minLength": 1
        },
        "lane": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "safepoint": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "pattern": "^[0-9]{8}_[0-9]{6}$"
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "governance",
        "sop",
        "ai_contract",
        "cr_schemas"
      ],
      "properties": {
        "governance": {
          "type": "string",
          "minLength": 1
        },
        "sop": {
          "type": "string",
          "minLength": 1
        },
        "ai_contract": {
          "type": "string",
          "minLength": 1
        },
        "cr_schemas": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "determiners": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script_paths",
        "folder_roots",
        "scheduled_tasks",
        "task_actions",
        "triggers",
        "ports_binds",
        "watchdog_restart"
      ],
      "properties": {
        "script_paths": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "None"
              ]
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "folder_roots": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "None"
              ]
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "scheduled_tasks": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "None"
              ]
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "task_path",
                  "name"
                ],
                "properties": {
                  "task_path": {
                    "type": "string",
                    "minLength": 1
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              }
            }
          ]
        },
        "task_actions": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "None"
              ]
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "execute",
                  "args"
                ],
                "properties": {
                  "execute": {
                    "type": "string",
                    "minLength": 1
                  },
                  "args": {
                    "type": "string"
                  },
                  "working_dir": {
                    "type": "string"
                  },
                  "run_as": {
                    "type": "string"
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              }
            }
          ]
        },
        "triggers": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "None"
              ]
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "ports_binds": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "None"
              ]
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "protocol",
                  "bind",
                  "port"
                ],
                "properties": {
                  "protocol": {
                    "type": "string",
                    "minLength": 1
                  },
                  "bind": {
                    "type": "string",
                    "minLength": 1
                  },
                  "port": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 65535
                  },
                  "path": {
                    "type": "string"
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              }
            }
          ]
        },
        "watchdog_restart": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "None"
              ]
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "enabled",
                "behavior"
              ],
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "behavior": {
                  "type": "string",
                  "minLength": 1
                },
                "restart_policy": {
                  "type": "string"
                },
                "health_check": {
                  "type": "string"
                },
                "notes": {
                  "type": "string"
                }
              }
            }
          ]
        }
      }
    },
    "assets_sealed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "run_start": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "known_issues": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "None"
          ]
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "resume_plan": {
      "type": "array",
      "minItems": 3,
      "maxItems": 7,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}